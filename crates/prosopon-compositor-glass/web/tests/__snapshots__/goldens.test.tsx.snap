// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`glass compositor goldens > demo_scene matches snapshot 1`] = `"<div><div class="pgl-node " data-node-id="root"><div class="pgl-section"><h2 class="pgl-section-title">Prosopon demo</h2><div class="pgl-divider"></div></div><div class="pgl-node " data-node-id="p1"><p class="pgl-prose">A prose child.</p></div><div class="pgl-node " data-node-id="tc"><div class="pgl-tool-call"><span style="color: var(--pgl-accent);">⚙ </span><strong>search</strong>({"q":"prosopon"})</div></div><div class="pgl-node " data-node-id="pr"><div class="pgl-progress"><div class="pgl-progress-track"><div class="pgl-progress-fill" style="width: 66%;"></div></div><span class="pgl-dim pgl-mono">66%</span><span class="pgl-dim">scoring</span></div></div></div></div>"`;

exports[`glass compositor goldens > streaming_tokens matches snapshot 1`] = `"<div><div class="pgl-node " data-node-id="root"><div class="pgl-section"><h2 class="pgl-section-title">Streaming tokens</h2><div class="pgl-divider"></div></div><div class="pgl-node " data-node-id="stream"><div class="pgl-mono pgl-dim" data-stream-id="chat">⟳ stream:chat (text)</div></div></div></div>"`;

exports[`glass compositor goldens > tool_flow matches snapshot 1`] = `"<div><div class="pgl-node " data-node-id="root"><div class="pgl-section"><h2 class="pgl-section-title">Tool flow</h2><div class="pgl-divider"></div></div><div class="pgl-node " data-node-id="tc"><div class="pgl-tool-call"><span style="color: var(--pgl-accent);">⚙ </span><strong>grep</strong>({"q":"needle"})</div></div><div class="pgl-node " data-node-id="tr"><div class="pgl-mono pgl-tool-result-ok">✓ ["a","b"]</div></div></div></div>"`;
