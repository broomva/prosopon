{
  "name": "@broomva/prosopon",
  "version": "0.2.0",
  "description": "TypeScript bindings for Prosopon — the Life Agent OS display server. IR types auto-generated from prosopon-core's JSON schemas; runtime helpers (codecs, reducer, WS/SSE client) hand-written. Wire-compatible with prosopon-protocol v1.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broomva/prosopon.git",
    "directory": "packages/prosopon-ts"
  },
  "homepage": "https://github.com/broomva/prosopon/tree/main/packages/prosopon-ts",
  "bugs": {
    "url": "https://github.com/broomva/prosopon/issues"
  },
  "keywords": [
    "prosopon",
    "agents",
    "display-server",
    "ir",
    "envelope",
    "sse",
    "websocket",
    "life-agent-os",
    "broomva"
  ],
  "author": "Carlos Escobar-Valbuena <carlosbvalbuena@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codec": {
      "types": "./dist/codec.d.ts",
      "import": "./dist/codec.js"
    },
    "./apply-event": {
      "types": "./dist/apply-event.d.ts",
      "import": "./dist/apply-event.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "import": "./dist/ids.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "generate": "bun run scripts/generate-types.ts",
    "test": "bun test",
    "prepublishOnly": "bun run clean && bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.8.0"
  }
}
